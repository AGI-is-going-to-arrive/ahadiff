# AHADIFF:GENERATED
name: AhaDiff Verify

on:
  pull_request:
    branches: [main]
  push:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read

concurrency:
  group: ahadiff-verify-${{ github.ref }}
  cancel-in-progress: true

jobs:
  verify:
    runs-on: macos-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install Python with current Homebrew SQLite
        run: |
          brew install python@3.12
          echo "$(brew --prefix python@3.12)/bin" >> "$GITHUB_PATH"

      - uses: astral-sh/setup-uv@v5
        with:
          enable-cache: true

      - name: Validate AhaDiff artifacts
        run: uvx --python python3.12 --from ahadiff ahadiff verify --ci
