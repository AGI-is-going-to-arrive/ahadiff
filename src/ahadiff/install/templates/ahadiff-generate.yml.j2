# AHADIFF:GENERATED
name: AhaDiff Generate

# Boundaries:
# - Keep provider credentials in environment variables.
# - Do not commit `.ahadiff/audit.private.jsonl`.
# - Treat `.ahadiff/` as local state.
# - Prefer verified claims with file-line evidence.
# - Do not upload `.ahadiff/` artifacts to external services without explicit user consent.

# Note: this workflow uploads artifacts only after explicit workflow_dispatch opt-in.

"on":
  workflow_dispatch:
    inputs:
      diff_ref:
        description: Git diff range to learn from.
        required: true
        default: HEAD~1..HEAD
      provider_class:
        description: AhaDiff provider class.
        required: true
        default: openai
      provider_base_url:
        description: Provider API base URL.
        required: true
      provider_model:
        description: Provider model name.
        required: true
        default: gpt-5.4-mini
      privacy_mode:
        description: Privacy mode for LLM generation.
        required: true
        default: redacted_remote

permissions:
  contents: read

concurrency:
  group: ahadiff-generate-${{ github.ref }}
  cancel-in-progress: true

jobs:
  generate:
    runs-on: ${{ matrix.os }}
    strategy:
      fail-fast: false
      matrix:
        os: [macos-latest, ubuntu-latest]
    env:
      PYTHON_VERSION: "3.12"
      SQLITE_AUTOCONF_VERSION: "3510300"
      SQLITE_DOWNLOAD_YEAR: "2026"
      AHADIFF_PROVIDER_API_KEY: ${{ secrets.AHADIFF_PROVIDER_API_KEY }}
      AHADIFF_DIFF_REF: ${{ inputs.diff_ref }}
      AHADIFF_PROVIDER_CLASS: ${{ inputs.provider_class }}
      AHADIFF_PROVIDER_BASE_URL: ${{ inputs.provider_base_url }}
      AHADIFF_PROVIDER_MODEL: ${{ inputs.provider_model }}
      AHADIFF_PRIVACY_MODE: ${{ inputs.privacy_mode }}
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Require opt-in LLM secret
        run: |
          test -n "$AHADIFF_PROVIDER_API_KEY" || {
            echo "AHADIFF_PROVIDER_API_KEY secret is required for Layer 2 generation" >&2
            exit 1
          }

      - name: Install Python with current Homebrew SQLite
        if: runner.os == 'macOS'
        run: |
          brew install python@${PYTHON_VERSION}
          echo "$(brew --prefix python@${PYTHON_VERSION})/bin" >> "$GITHUB_PATH"

      - uses: actions/setup-python@v5
        if: runner.os == 'Linux'
        with:
          python-version: ${{ env.PYTHON_VERSION }}

      - name: Install SQLite runtime on Linux
        if: runner.os == 'Linux'
        run: |
          sqlite_url="https://www.sqlite.org/${SQLITE_DOWNLOAD_YEAR}/sqlite-autoconf-${SQLITE_AUTOCONF_VERSION}.tar.gz"
          curl -fsSLo "$RUNNER_TEMP/sqlite.tar.gz" "$sqlite_url" || \
            curl -fsSLo "$RUNNER_TEMP/sqlite.tar.gz" \
              "https://www.sqlite.org/2025/sqlite-autoconf-${SQLITE_AUTOCONF_VERSION}.tar.gz"
          tar -xzf "$RUNNER_TEMP/sqlite.tar.gz" -C "$RUNNER_TEMP"
          cd "$RUNNER_TEMP/sqlite-autoconf-${SQLITE_AUTOCONF_VERSION}"
          ./configure --prefix="$RUNNER_TEMP/sqlite" --disable-static
          make -j"$(nproc)"
          make install
          echo "LD_LIBRARY_PATH=$RUNNER_TEMP/sqlite/lib:${LD_LIBRARY_PATH:-}" >> "$GITHUB_ENV"

      - uses: astral-sh/setup-uv@v5
        with:
          enable-cache: true

      - name: Generate AhaDiff lesson artifacts
        run: |
          uvx --python python3.12 --from ahadiff ahadiff learn "$AHADIFF_DIFF_REF" \
            --provider-class "$AHADIFF_PROVIDER_CLASS" \
            --base-url "$AHADIFF_PROVIDER_BASE_URL" \
            --model "$AHADIFF_PROVIDER_MODEL" \
            --api-key-env AHADIFF_PROVIDER_API_KEY \
            --privacy-mode "$AHADIFF_PRIVACY_MODE"

      - name: Upload AhaDiff artifacts
        uses: actions/upload-artifact@v4
        with:
          name: ahadiff-artifacts
          path: |
            .ahadiff/runs/**
            .ahadiff/review.sqlite
            .ahadiff/results.tsv
            .ahadiff/concepts.jsonl
          if-no-files-found: warn
